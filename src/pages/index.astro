---
import Base from "../layouts/Base.astro";
import CollectionCard from "../components/CollectionCard.astro";
import { getCollections } from "../lib/collections";
import { SITE } from "../lib/site";

const collections = getCollections();

// Use the newest cover as the home-page share image.
let og: string | undefined;
if (collections[0]) {
  const { getImage } = await import("astro:assets");
  const img = await getImage({ src: collections[0].cover, width: 1200, format: "jpeg", quality: 82 });
  og = img.src;
}
---

<Base title={SITE.name} description={SITE.description} ogImage={og}>
  <section class="intro">
    <p class="prose lede">{SITE.intro}</p>
    <p class="meta-line follow">
      New work goes up on <a href={SITE.instagram} target="_blank" rel="me noopener">Instagram</a> first.
      {SITE.showAllFeed && <> Or browse <a href="/all">every photo →</a></>}
    </p>
  </section>

  {collections.length === 0 ? (
    <p class="prose empty">No collections yet. Drop a folder of photos into <code>src/content/collections/</code> to begin.</p>
  ) : (
    <div class="grid">
      {collections.map((c, i) => (
        <CollectionCard collection={c} eager={i < 3} />
      ))}
    </div>
  )}

  <style>
    .intro {
      max-width: var(--maxw-photo);
      margin: clamp(3rem, 9vw, 6rem) auto clamp(2.5rem, 7vw, 4rem);
      padding-inline: var(--gutter);
    }
    .lede { font-size: clamp(1.25rem, 3.5vw, 1.75rem); line-height: 1.35; }
    .follow { margin-top: 1.2rem; }
    .follow a { text-decoration: underline; }

    .grid {
      max-width: var(--maxw-photo);
      margin: 0 auto;
      padding-inline: var(--gutter);
      display: grid;
      grid-template-columns: 1fr;
      gap: clamp(1.75rem, 5vw, 3rem) clamp(1.25rem, 3vw, 2rem);
    }
    @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
    @media (min-width: 1000px) { .grid { grid-template-columns: repeat(3, 1fr); } }

    .empty {
      max-width: var(--maxw-photo);
      margin-inline: auto;
      padding-inline: var(--gutter);
    }
    code { font-family: var(--font-mono); font-size: 0.85em; }
  </style>
</Base>

---
import Base from "../layouts/Base.astro";
import Photo from "../components/Photo.astro";
import { getAllPhotos } from "../lib/collections";
import { SITE } from "../lib/site";

const all = getAllPhotos();
---

<Base title="All photos" description={`Every photo from ${SITE.name}, newest first.`}>
  <section class="head">
    <p class="eyebrow">The stream</p>
    <h1 class="title">All photos</h1>
    <p class="meta-line sub">{all.length} {all.length === 1 ? "frame" : "frames"}, newest first</p>
  </section>

  {all.length === 0 ? (
    <p class="prose empty">No photos yet.</p>
  ) : (
    <div class="stream">
      {all.map(({ photo, collection }, i) => (
        <div class="frame">
          <Photo photo={photo} eager={i === 0} showCaption={false} />
          <a class="from meta-line" href={`/c/${collection.slug}#p-${photo.index}`}>
            {photo.caption ? `${photo.caption} — ` : ""}{collection.title} ↗
          </a>
        </div>
      ))}
    </div>
  )}

  <style>
    .head {
      max-width: var(--maxw-photo);
      margin: clamp(2rem, 6vw, 4rem) auto clamp(2.5rem, 7vw, 4rem);
      padding-inline: var(--gutter);
    }
    .title {
      font-family: var(--font-ui);
      font-weight: 600;
      font-size: clamp(1.7rem, 5vw, 2.7rem);
      letter-spacing: -0.01em;
      margin-top: 0.4rem;
    }
    .sub { margin-top: 0.7rem; }
    .stream {
      max-width: var(--maxw-photo);
      margin: 0 auto;
      padding-inline: var(--gutter);
      display: flex;
      flex-direction: column;
      gap: var(--photo-gap);
    }
    @media (max-width: 640px) { .stream { padding-inline: clamp(0.4rem, 3vw, 1rem); } }
    .from { display: inline-block; margin-top: 0.8rem; color: var(--muted); }
    .empty { max-width: var(--maxw-photo); margin-inline: auto; padding-inline: var(--gutter); }
  </style>
</Base>

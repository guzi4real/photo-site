---
import { SITE } from "../lib/site";

const path = Astro.url.pathname;
const isHome = path === "/";
---

<header class="nav">
  <a class="wordmark" href="/" aria-current={isHome ? "page" : undefined}>
    <span class="dot"></span>{SITE.name}
  </a>

  <nav class="links" aria-label="Primary">
    {SITE.showAllFeed && <a href="/all" aria-current={path.startsWith("/all") ? "page" : undefined}>All</a>}
    {SITE.showPosts && <a href="/posts" aria-current={path.startsWith("/posts") ? "page" : undefined}>Writing</a>}
    <a href="/about" aria-current={path.startsWith("/about") ? "page" : undefined}>About</a>
    <a href={SITE.instagram} target="_blank" rel="me noopener">Instagram</a>

    <button id="theme-toggle" type="button" class="toggle" aria-label="Switch colour theme" title="Switch theme">
      <svg class="sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4" />
      </svg>
      <svg class="moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
      </svg>
    </button>
  </nav>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    function current() {
      var set = document.documentElement.getAttribute("data-theme");
      if (set === "light" || set === "dark") return set;
      return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
    }
    btn.addEventListener("click", function () {
      var next = current() === "dark" ? "light" : "dark";
      document.documentElement.setAttribute("data-theme", next);
      try { localStorage.setItem("theme", next); } catch (e) {}
    });
  })();
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem var(--gutter);
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .wordmark {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.86rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
  .links {
    display: flex;
    align-items: center;
    gap: clamp(0.85rem, 3vw, 1.6rem);
    font-size: 0.82rem;
    letter-spacing: 0.02em;
  }
  .links a[aria-current="page"] { text-decoration: underline; }
  .toggle {
    display: inline-grid;
    place-items: center;
    width: 30px; height: 30px;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    border-radius: 50%;
  }
  .toggle:hover { background: color-mix(in srgb, var(--ink) 8%, transparent); }
  .toggle .moon { display: none; }
  :global(:root[data-theme="dark"]) .toggle .sun { display: none; }
  :global(:root[data-theme="dark"]) .toggle .moon { display: block; }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme="light"])) .toggle .sun { display: none; }
    :global(:root:not([data-theme="light"])) .toggle .moon { display: block; }
  }
</style>
